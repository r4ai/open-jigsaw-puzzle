{
  "name": "@open-jigsaw-puzzle/web-solid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "panda:gen": "panda codegen",
    "dev": "panda codegen && vite --host 0.0.0.0",
    "build": "panda codegen && tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "panda codegen && vitest run --passWithNoTests",
    "typecheck": "panda codegen && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.2",
    "@open-jigsaw-puzzle/shared": "workspace:*",
    "@solidjs/router": "^0.16.1",
    "lucide-solid": "^1.16.0",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.0.15"
  }
