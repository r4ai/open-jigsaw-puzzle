{
  "name": "@open-jigsaw-puzzle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:wrangler": "node scripts/prepare-wrangler-config.mjs",
    "dev": "pnpm prepare:wrangler && wrangler dev --config wrangler.generated.jsonc",
    "build": "tsc -p tsconfig.json",
    "deploy": "pnpm prepare:wrangler && wrangler deploy --config wrangler.generated.jsonc",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@open-jigsaw-puzzle/shared": "workspace:*",
    "@valibot/to-json-schema": "^1.7.0",
    "hono": "^4.10.7",
    "hono-openapi": "^1.3.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.55.0"
  }
}
